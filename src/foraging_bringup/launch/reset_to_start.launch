<launch>
    <!-- orientation.z from OptiTrack when robot is at start with correct orientation -->
    <arg name="goal_orientation_z"  default="-0.4383017122745514"/>

    <!-- Tolerance in orientation.z units (0.01 ≈ 1 deg) -->
    <arg name="tolerance"           default="0.01"/>

    <!-- Velocity limits -->
    <arg name="max_angular_vel"     default="0.40"/>
    <arg name="k_ang"               default="2.0"/>

    <!-- Direct-drive reset node -->
    <node name="reset_to_start" pkg="foraging_bringup" type="reset_to_start_node.py" output="screen">
        <param name="goal_orientation_z"  value="$(arg goal_orientation_z)"/>
        <param name="tolerance"           value="$(arg tolerance)"/>
        <param name="max_angular_vel"     value="$(arg max_angular_vel)"/>
        <param name="k_ang"               value="$(arg k_ang)"/>
    </node>
</launch>
