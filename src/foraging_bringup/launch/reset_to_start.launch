<launch>
    <!-- Start pose in OptiTrack frame -->
    <arg name="start_x"          default="0.0"/>
    <arg name="start_y"          default="0.0"/>
    <arg name="start_yaw"        default="0.0"/>

    <!-- Tolerances for declaring success -->
    <arg name="pos_tolerance"    default="0.10"/>
    <arg name="yaw_tolerance"    default="0.15"/>

    <!-- Max correction attempts -->
    <arg name="max_corrections"  default="5"/>

    <!-- Per-attempt timeout (seconds) -->
    <arg name="nav_timeout"      default="60.0"/>

    <!-- Velocity limits -->
    <arg name="max_linear_vel"   default="0.20"/>
    <arg name="max_angular_vel"  default="0.60"/>

    <!-- Direct-drive reset node (no move_base needed) -->
    <node name="reset_to_start" pkg="foraging_bringup" type="reset_to_start_node.py" output="screen">
        <param name="start_x"          value="$(arg start_x)"/>
        <param name="start_y"          value="$(arg start_y)"/>
        <param name="start_yaw"        value="$(arg start_yaw)"/>
        <param name="pos_tolerance"    value="$(arg pos_tolerance)"/>
        <param name="yaw_tolerance"    value="$(arg yaw_tolerance)"/>
        <param name="max_corrections"  value="$(arg max_corrections)"/>
        <param name="nav_timeout"      value="$(arg nav_timeout)"/>
        <param name="max_linear_vel"   value="$(arg max_linear_vel)"/>
        <param name="max_angular_vel"  value="$(arg max_angular_vel)"/>
    </node>
</launch>
