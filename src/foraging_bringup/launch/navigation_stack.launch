<launch>
    <arg name="open_rviz" default="true"/>

    <!-- ===== SLAM ===== -->
    <include file="$(find foraging_bringup)/launch/gmapping.launch"/>

    <!-- ===== Navigation ===== -->
    <include file="$(find foraging_bringup)/launch/move_base.launch"/>

    <!-- ===== Perception (puck + ArUco pipelines) ===== -->
    <include file="$(find foraging_bringup)/launch/perception.launch"/>

    <!-- ===== Foraging service servers ===== -->
    <include file="$(find foraging_bringup)/launch/services.launch"/>

    <!-- ===== Robot description (URDF with gripper) ===== -->
    <param name="robot_description"
           command="$(find xacro)/xacro '$(find rosbot_description)/urdf/rosbot.xacro'"/>
    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher"/>
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/>

    <!-- ===== Visualization ===== -->
    <group if="$(arg open_rviz)">
        <node pkg="rviz" type="rviz" name="rviz"
              args="-d $(find foraging_bringup)/rviz/foraging_rviz_config.rviz"/>
    </group>
</launch>
