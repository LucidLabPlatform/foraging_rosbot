<launch>
    <arg name="open_rviz" default="true"/>

    <!-- gmapping and move_base must be launched separately FIRST:
         1) roslaunch foraging_bringup gmapping.launch
         2) roslaunch foraging_bringup move_base.launch
         Then launch this file (via foraging_experiment.launch). -->

    <!-- ===== Perception (puck + ArUco pipelines) ===== -->
    <include file="$(find foraging_bringup)/launch/perception.launch"/>

    <!-- ===== Foraging service servers ===== -->
    <include file="$(find foraging_bringup)/launch/services.launch"/>

    <!-- ===== Visualization ===== -->
    <!-- robot_state_publisher and joint_state_publisher are NOT launched here
         because the ROSbot Docker containers already publish the full TF tree
         (odom -> base_link -> all sensors). Running a second instance corrupts TF. -->
    <group if="$(arg open_rviz)">
        <node pkg="rviz" type="rviz" name="rviz"
              args="-d $(find foraging_bringup)/rviz/foraging_rviz_config.rviz"/>
    </group>
</launch>
