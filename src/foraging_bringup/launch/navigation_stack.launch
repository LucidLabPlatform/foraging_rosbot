<launch>
    <!-- ===== SLAM and NAV ===== -->
    <node pkg="gmapping" type="slam_gmapping" name="gmapping_node" output="log">
        <param name="base_frame"            value="base_link"/>
        <param name="odom_frame"            value="odom"/>
        <param name="map_update_interval"   value="1.5"/>
        <param name="maxUrange"             value="15.0"/>
        <param name="delta"                 value="0.03"/>
        <param name="xmin"                  value="-10"/>
        <param name="ymin"                  value="-10"/>
        <param name="xmax"                  value="10"/>
        <param name="ymax"                  value="10"/>
    </node>
    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <rosparam file="$(find foraging_bringup)/config/move_base.yaml"       command="load"/>
        <rosparam file="$(find foraging_bringup)/config/costmap_common.yaml"  command="load" ns="global_costmap"/>
        <rosparam file="$(find foraging_bringup)/config/costmap_common.yaml"  command="load" ns="local_costmap"/>
        <rosparam file="$(find foraging_bringup)/config/costmap_global.yaml"  command="load"/>
        <rosparam file="$(find foraging_bringup)/config/costmap_local.yaml"   command="load"/>
        <rosparam file="$(find foraging_bringup)/config/planner_global.yaml"  command="load"/>
        <rosparam file="$(find foraging_bringup)/config/planner_local.yaml"   command="load"/>
    </node>



    <!-- ===== FORAGING BEHAVIOUR ===== -->

    <!-- ===== find pucks ===== -->
    <node pkg="foraging_puck" type="1_perception_node.py" name="perception_node"  output="screen">
    </node>
    <node pkg="foraging_puck" type="2_depth_perception_node.py" name="puck_depth_node"  output="screen">
    </node>
    <node pkg="foraging_puck" type="3_puck_global_pos.py" name="puck_localization_node"  output="screen">
    </node>
    <node pkg="foraging_puck" type="4_pub_puck_tf.py" name="puck_tf_broadcaster_node"  output="screen">
    </node>
    <!-- ===== put pucks TF as obsticles ===== -->
    <node pkg="foraging_puck" type="5_puck_obsticle_publisher.py" name="puck_obstacle_publisher"  output="screen">
    </node>

    <!-- ===== while conditions not satisfied -> move around random, explore, find pucks, and corners ===== -->
    <!-- ===== when conditions satisfied -> go grab pucks one by one and bring them to their respective homes ===== -->
    <!-- ===== put pucks TF as obsticles ===== -->



    <!-- ===== VISUALIZATION ===== -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find foraging_bringup)/rviz/foraging_rviz_config.rviz"/>

</launch>